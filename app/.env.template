# Heartland Commons — Environment Variables
# =========================================
# Copy this file to app/.env and fill in your values.
# NEVER commit app/.env to source control.

# ── Vertex AI (the Live model) ──────────────────────────────────────────────
# Use Vertex AI, not AI Studio.
GOOGLE_GENAI_USE_VERTEXAI=1

# Your GCP project id.
GOOGLE_CLOUD_PROJECT=heartland-commons

# REGION STRATEGY (see README "Region strategy"):
# The Gemini Live native-audio model is hosted in us-central1 (availability).
# ALL stored merchant data lives in asia-southeast1 (PDPA) — that is the
# Firestore database location, set when the database is created, NOT here.
GOOGLE_CLOUD_LOCATION=us-central1

# Current Gemini Live API model id — VERIFY before each session:
# https://cloud.google.com/vertex-ai/generative-ai/docs/learn/models
DEMO_AGENT_MODEL=gemini-live-2.5-flash-native-audio

# Prebuilt voice for the Copilot (warm, natural).
COPILOT_VOICE=Aoede

# ── Firestore (per-tenant data, asia-southeast1) ────────────────────────────
# The database id. The database behind it MUST be created in asia-southeast1
# for PDPA residency. '(default)' is fine if your default DB is in SG.
FIRESTORE_DATABASE=(default)

# ── SEA-LION localisation (ADR-2) ───────────────────────────────────────────
# URL of your SELF-HOSTED SEA-LION post-processing service (Cloud Run,
# asia-southeast1). Leave BLANK for v1 — localisation becomes an identity
# pass-through and the product still works. NEVER point this at an external
# SEA-LION API — merchant text must not leave our infrastructure.
SEA_LION_URL=

# ── adk web routing tests only ──────────────────────────────────────────────
# Set to 1 ONLY when running `adk web` (native-audio rejects generateContent).
# The FastAPI voice server leaves this at 0.
ADK_WEB=0
